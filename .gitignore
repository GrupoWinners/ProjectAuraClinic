# ==============================================================================
# ARQUIVO .GITIGNORE 
# ==============================================================================

# ==============================================================================
# 1. Pastas e Arquivos Específicos do Projeto
# ==============================================================================
# Ignora a pasta de documentação solicitada (incluindo variações de nome)
/documentação das etapas/
/documentacao das etapas/
/Documentação das Etapas/
/Documentacao das Etapas/

# ==============================================================================
# 2. Build e Compilação
# ==============================================================================
# Ignora arquivos compilados e diretórios de build
**/target/
**/.mvn/
**/.idea/
**/.settings/
**/.classpath
**/.project
**/*.iml
.git/
.gitignore

# arquivos de sistema
.DS_Store
Thumbs.db

# logs
*.log
# ==============================================================================
# 3. Maven
# ==============================================================================
# Ignora arquivos temporários e logs do Maven
.mvn/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

# ==============================================================================
# 4. Gradle
# ==============================================================================
# Ignora caches e arquivos gerados pelo Gradle
.gradle/
!gradle/wrapper/gradle-wrapper.jar

# ==============================================================================
# 5. IDEs e Editores de Código
# ==============================================================================

# -> IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# -> Eclipse
.apt_generated/
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache/

# -> Visual Studio Code
.vscode/
*.code-workspace

# ==============================================================================
# 6. Sistema Operacional
# ==============================================================================

# -> Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -> macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# -> Linux
*~
.directory

# ==============================================================================
# 7. Logs e Arquivos Temporários
# ==============================================================================
# Ignora arquivos de log e arquivos temporários de editores
*.log
*.tmp
*.bak
*.swp

# ==============================================================================
# 8. Variáveis de Ambiente e Segredos (MUITO IMPORTANTE)
# ==============================================================================
# NUNCA comite arquivos com senhas, chaves de API ou configurações locais!
.env
.env.local
.env.*.local
application-local.yml
application-local.properties
secrets.yml
pdf_content.txt
docs/Sem título.pdf
*.pdf

# ==============================================================================
# 9. Spring Boot — Configurações com Segredos
# ==============================================================================
# application-dev.yml contém JWT secret hardcoded e credenciais locais de banco
# Cada desenvolvedor deve criar o seu próprio a partir do application-dev.yml.example
application-dev.yml

# application-prod.yml referencia variáveis de ambiente sensíveis — não commitado
# para evitar exposição acidental de nomes de variáveis e estrutura de produção
application-prod.yml

# Arquivos de override local nunca devem ir para o repositório
application-override.yml
application-*.local.yml

# ==============================================================================
# 10. Docker e Infraestrutura
# ==============================================================================
# Arquivos docker com credenciais embutidas
docker-compose.override.yml
.docker/
*.env

# ==============================================================================
# 11. Relatórios e Arquivos Gerados por Ferramentas
# ==============================================================================
*.log
*.tmp
*.bak
*.swp
# Pasta target do Maven (build artifacts)
**/target/
