server:
  port: 8081

spring:
  application:
    name: admin-service

  profiles:
    active: dev

  datasource:
    url: jdbc:mysql://localhost:3306/admin_db
    username: SEU_USUARIO_MYSQL
    password: SUA_SENHA_MYSQL
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.MySQLDialect

# INSTRUÇÃO: Gere sua própria chave com: openssl rand -base64 64
# A chave deve ter no mínimo 256 bits (32 bytes em Base64)
jwt:
  chave-secreta: SUBSTITUA_PELA_SUA_CHAVE_BASE64_DE_NO_MINIMO_256_BITS
  expiracao: 86400000

springdoc:
  api-docs:
    path: /api-docs
  swagger-ui:
    path: /swagger-ui.html

logging:
  level:
    br.com.clinica: DEBUG
    org.springframework.web: DEBUG
    org.hibernate.SQL: DEBUG
    org.hibernate.orm.jdbc.bind: TRACE
  pattern:
    console: "%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n"
